# Copia este archivo a .env y rellena tus propios valores. Nunca subas .env a git.

PORT=3000
NODE_ENV=production

# Cualquier cadena larga y aleatoria (ej: openssl rand -hex 32)
SESSION_SECRET=cambia-esto-por-algo-largo-y-aleatorio

# La contraseña con la que entrarás al panel desde cualquier dispositivo
APP_PASSWORD=cambia-esta-contraseña

# Contraseña aparte para la vista de solo lectura del médico (/doctor)
DOCTOR_PASSWORD=cambia-esta-otra-contraseña

# URL /exec que te da Apps Script al publicar el Web App
SHEETS_WEBAPP_URL=https://script.google.com/macros/s/AKfycb.../exec

# El mismo valor que pusiste en Script Properties como BP_API_TOKEN
SHEETS_TOKEN=cambia-esto-tambien-por-algo-largo-y-aleatorio
